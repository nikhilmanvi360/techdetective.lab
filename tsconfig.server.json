{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": false,
    "inlineSources": false
  },
  "include": [
    "server.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.tsx",
    "node_modules",
    "dist",
    "v2-frontend"
  ]
}
