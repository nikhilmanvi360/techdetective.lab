# Required Environment Variables — Tech Detective

# Supabase (required)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# JWT Secret (required — generate with: openssl rand -base64 32)
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET

# Optional: Gemini AI for the Game Advisor
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: Redis for BullMQ job queue (mission execution)
# If not set, mission execution falls back to synchronous sandbox
REDIS_URL=redis://localhost:6379

# App URL (set in production)
APP_URL=http://localhost:3000
