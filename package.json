{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && tsx scripts/build-server.ts",
    "start": "node dist/server.cjs",
    "pretest": "node -e \"import('fs').then(m => m.copyFileSync('database/lab.db', 'database/test.db'))\"",
